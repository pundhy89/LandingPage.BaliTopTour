rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidAppSettings(data) {
      return data.keys().hasAll(['appTitle', 'appSubtitle'])
        && data.appTitle is string && data.appTitle.size() <= 100
        && data.appSubtitle is string && data.appSubtitle.size() <= 100;
    }

    match /appSettings/{documentId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
